{
  "name": "chat-capsule",
  "version": "1.0.0",
  "description": "macOS-first, local-only, read-only WeChat history viewer, analyzer, and exporter",
  "main": "dist-electron/main.js",
  "author": "magic8ytes",
  "repository": {
    "type": "git",
    "url": "https://github.com/magic8ytes/Chat-Capsule.git"
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps && node scripts/fix-sherpa-rpath.mjs",
    "rebuild": "electron-rebuild && node scripts/fix-sherpa-rpath.mjs",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "build:web": "vite build --mode web",
    "build:electron": "npm run typecheck && vite build",
    "pack:mac": "npm run build:electron && electron-builder --config electron-builder.config.mjs --mac dmg zip",
    "build": "npm run pack:mac",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:build": "npm run build:electron",
    "build:mac": "npm run build",
    "check:release-config": "node scripts/release-preflight.mjs",
    "validate:ci": "npm run check:release-config && npm run typecheck && npm run lint && npm run lint:secrets && npm run build:electron",
    "validate:release": "npm run validate:ci && npm run pack:mac",
    "lint": "node scripts/security-lint.mjs",
    "lint:secrets": "node scripts/secret-scan.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "ffmpeg-static": "^5.3.0",
    "fzstd": "^0.1.1",
    "html2canvas": "^1.4.1",
    "jieba-wasm": "^2.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.1",
    "react-virtuoso": "^4.18.1",
    "remark-gfm": "^4.0.1",
    "sherpa-onnx-node": "^1.10.38",
    "silk-wasm": "^3.7.1",
    "wechat-emojis": "^1.0.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^39.2.7",
    "electron-builder": "^25.1.8",
    "sass": "^1.83.0",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "homepage": "https://github.com/magic8ytes/Chat-Capsule",
  "bugs": {
    "url": "https://github.com/magic8ytes/Chat-Capsule/issues"
  },
  "license": "CC-BY-NC-SA-4.0",
  "keywords": [
    "electron",
    "react",
    "typescript",
    "macos",
    "wechat",
    "history",
    "viewer",
    "analytics",
    "export"
  ]
}
